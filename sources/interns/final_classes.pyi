from __future__ import annotations

from types import NoneType

from sources.resources.texture import JETexture
from sources.resources.font import JEFont
from sources.interns.low_classes import JEInternGraphic
from sources.systems.container import JEContainer
from sources.entities.entity import JEEntity

class JEInternEmptyComponent:
    def __init__(self, owner: JEEntity): ...
    def __call__(self) -> NoneType: ...
    def __bool__(self) -> bool: ...
    def copy(self, new_owner: JEEntity) -> JEInternEmptyComponent: ...

class JEInternRessources:
    def __init__(self): ...
    @property
    def texture(self) -> JEContainer[JETexture]: ...
    @property
    def animations(self) -> JEContainer[JEInternGraphic]: ...
    @property
    def font(self) -> JEContainer[JEFont]: ...

class JEInternWindowSettings:
    def __init__(self, size: tuple[int, int], flags: int,fps: int, depth: int, display: int, vsync: int, title: str): ...
    @property
    def size(self) -> tuple[int, int]: ...
    @size.setter
    def size(self, size: tuple[int, int]): ...
    @property
    def flags(self) -> int: ...
    @property
    def fps(self) -> int: ...
    @fps.setter
    def fps(self, fps: int): ...
    @property
    def depth(self) -> int: ...
    @property
    def display(self) -> int: ...
    @property
    def vsync(self) -> int: ...
    @property
    def title(self) -> str: ...
    @title.setter
    def title(self, title: str): ...
    def __deepcopy__(self, memo): ...
